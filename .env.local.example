# 在 Remix 部署合约后，把地址填入这里
# 然后把此文件复制为 .env.local

# WizperToken (ERC-20) 合约地址
NEXT_PUBLIC_WIZPER_TOKEN_ADDRESS=0x

# WizperNFT (ERC-721) 合约地址
NEXT_PUBLIC_WIZPER_NFT_ADDRESS=0x

# 链 ID (Base Sepolia = 84532)
NEXT_PUBLIC_CHAIN_ID=84532

# Pinata IPFS (https://app.pinata.cloud/developers/api-keys 获取)
PINATA_JWT=
NEXT_PUBLIC_PINATA_GATEWAY=
